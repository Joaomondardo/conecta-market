# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=conecta
POSTGRES_PASSWORD=conecta123
POSTGRES_DB=conecta_market
DATABASE_URL="postgresql://conecta:conecta123@localhost:5432/conecta_market?schema=public"

# ─── MongoDB ──────────────────────────────────────────────────────
MONGO_USER=conecta
MONGO_PASSWORD=conecta123
MONGO_DB=conecta_logs
MONGODB_URI="mongodb://conecta:conecta123@localhost:27017/conecta_logs?authSource=admin"

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=conecta123
REDIS_URL="redis://:conecta123@localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth (opcional - deixar vazio para desativar) ────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Email (SMTP - opcional) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Conecta Market <noreply@conectamarket.com.br>"

# ─── Upload ───────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ─── pgAdmin (opcional) ───────────────────────────────────────────
PGADMIN_EMAIL=admin@conecta.market
PGADMIN_PASSWORD=admin123
