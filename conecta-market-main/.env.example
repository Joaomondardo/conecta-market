# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=placeholder_user
POSTGRES_PASSWORD=placeholder_password
POSTGRES_DB=conecta_market
DATABASE_URL="postgresql://placeholder_user:placeholder_password@localhost:5432/conecta_market?schema=public"

# ─── MongoDB ──────────────────────────────────────────────────────
MONGO_USER=placeholder_user
MONGO_PASSWORD=placeholder_password
MONGO_DB=conecta_logs
MONGODB_URI="mongodb://placeholder_user:placeholder_password@localhost:27017/conecta_logs?authSource=admin"

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=placeholder_password
REDIS_URL="redis://:placeholder_password@localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────
# Use uma chave forte com pelo menos 32 caracteres.
JWT_SECRET=placeholder_super_secret_jwt_key_at_least_32_characters_long
JWT_REFRESH_SECRET=placeholder_super_secret_refresh_key_at_least_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth (opcional) ──────────────────────────────────────
GOOGLE_CLIENT_ID=placeholder_google_client_id
GOOGLE_CLIENT_SECRET=placeholder_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=placeholder_email@gmail.com
SMTP_PASS=placeholder_email_password
SMTP_FROM="Conecta Market <noreply@conectamarket.com.br>"

# ─── Upload ───────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ─── pgAdmin (opcional) ───────────────────────────────────────────
PGADMIN_EMAIL=admin@conecta.market
PGADMIN_PASSWORD=placeholder_admin_password
